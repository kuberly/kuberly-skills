# Override the dev-server proxy target. Default: http://127.0.0.1:8000.
# VITE_API_BASE=http://127.0.0.1:8000

# When the SPA is built into the Docker image and served behind nginx, the
# nginx config proxies /api/* to KUBERLY_GRAPH_BACKEND (set on the container,
# not the SPA). The browser only sees same-origin requests, so VITE_API_BASE
# is left unset for prod builds.
