{
  "name": "kuberly-graph-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone SPA for the kuberly-graph dashboard. Calls the kuberly-graph MCP server's /api/v1/* HTTP endpoints; ships as a static bundle (Docker + nginx in prod).",
  "scripts": {
    "dev": "vite",
    "build": "tsgo -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsgo -p tsconfig.app.json && tsgo -p tsconfig.node.json",
    "typecheck:tsc": "tsc -b --noEmit",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.10",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-3d": "^1.26.1",
    "three": "^0.171.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.171.0",
    "@typescript/native-preview": "^7.0.0-dev.20260508.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
